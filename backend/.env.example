ENOKI_PRIVATE_KEY=
PORT=3001
NODE_ENV=development
FAUCET_WINDOW_MS=3600000
FAUCET_MAX_REQUESTS_PER_WINDOW=3
FAUCET_REDIRECT_URL=https://tally.so/r/Xx102L

# Predict package (indexer subscribes to its MintEvent/RedeemEvent/SettleEvent).
FATHOM_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
# Fathom router package (indexer subscribes to HedgedSwapExecuted from Smart Bets).
FATHOM_ROUTER_PACKAGE_ID=0x92555862cc0dbcedfd6f7ff15bc5ebf42e5bc33e81bf87dac0e611bf45e1c89c

FATHOM_VAULT_PACKAGE_ID=0xbb29a9db48656dec459fb1109e5e0a639b45008301daf6fa4db506ffd54c4acb
FATHOM_VAULT_OBJECT_ID=0x79349ee228c7312654bbe582909a33c37de31f543d269638545593b6cee0b278
FATHOM_VAULT_ADMIN_ADDRESS=0x076a67589159074d5c29ccddc1c24f7c34a4c3527502e55f182e10f5bc0bd606
FATHOM_KEEPER_PRIVATE_KEY=
FATHOM_VAULT_MIN_IDLE_BPS=2500
FATHOM_VAULT_MAX_SINGLE_DEPLOY_BPS=2000
FATHOM_VAULT_MAX_TOTAL_DEPLOYED_BPS=7000
FATHOM_VAULT_MAX_EXPOSURE_BPS=5000

# Indexer / persistence.
# Default DB path is ./data/fathom.sqlite (relative to backend cwd).
FATHOM_DB_PATH=
# Set INDEXER_ENABLED=false to skip polling on boot (used by tests).
INDEXER_ENABLED=true

# Sponsorship anti-abuse: max sponsored txs per sender per rolling 24h window.
SPONSORSHIP_DAILY_LIMIT_TX_COUNT=50

# Predict object + server (indexer ingests live oracle metadata from here).
FATHOM_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
FATHOM_PREDICT_SERVER_URL=https://predict-server.testnet.mystenlabs.com

# dUSDC Move type — used by the keeper to call vault::keeper_update_exposure<Quote>.
FATHOM_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC

# Keeper behavior. Submit only when |indexer_aggregate - on_chain| > threshold,
# and at most once per cooldown.
FATHOM_KEEPER_DIVERGENCE_MIN_MICRO=1000000
FATHOM_KEEPER_COOLDOWN_MS=60000
FATHOM_KEEPER_INTERVAL_MS=15000

# /health flips to degraded (HTTP 503) if poller hasn't ticked / any cursor hasn't
# advanced in this many ms. Tune for your RPC latency profile.
INDEXER_STALE_ALARM_MS=30000
