# ──────────────────────────────────────────────────────────────────────────
# Brisk — backend (sponsor relay) env. Copy to backend/.env and fill in.
# This file holds SECRETS — never commit backend/.env.
# ──────────────────────────────────────────────────────────────────────────

# Enoki PRIVATE API key (sponsorship). Server-side only — never ship in the app.
ENOKI_PRIVATE_KEY=

PORT=3001
NODE_ENV=development

# Testnet faucet proxy (rate-limited) for topping up zkLogin addresses with gas.
FAUCET_WINDOW_MS=3600000
FAUCET_MAX_REQUESTS_PER_WINDOW=3

# Sponsorship anti-abuse: max sponsored txs per sender per rolling 24h window.
SPONSORSHIP_DAILY_LIMIT_TX_COUNT=50
# Global circuit breaker: max sponsored txs per day across ALL senders.
SPONSORSHIP_GLOBAL_DAILY_MAX=5000

# Brisk Move package (testnet). REQUIRED — the relay fails closed (sponsors
# nothing) if unset, so the move-call allowlist stays authoritative.
BRISK_PACKAGE_ID=0xcbd54ab52fad4110fdad2d9fd8e92e84dd87db436f2b608cc47819f7d4fd03cc

# Upgraded package id that added payment_receipt::record_payment (the best-effort
# receipt leg). Defaults to BRISK_PACKAGE_ID when unset.
BRISK_RECORD_PKG=0x3ac880a1eab2763fc1b92376a88e1913d0bc4dbf02023a3c0a0321d16c2837cb

# Upgraded package (2026-06-08) carrying the `till` module (merchant receiving
# accounts). till::* targets are allowlisted for sponsorship. Defaults to
# BRISK_PACKAGE_ID when unset.
BRISK_TILL_PKG=0xe96ec7f8b0633204af0a4060cc10adeac019641d1ec71096f0567071885b1e35

# Upgraded package (2026-06-09) carrying the `gift_card` module (on-chain
# escrowed, claimable gift cards). gift_card::{mint,claim,redeem} are allowlisted
# for sponsorship (and must also be on the Enoki dashboard allowlist). Defaults
# to BRISK_PACKAGE_ID when unset.
BRISK_GIFT_CARD_PKG=0xc90ebfadb58657be143a09342d575223681587de6eb87efe006d720edc0b6a86

# Public faucet the /api/faucet/request proxy redirects to.
FAUCET_REDIRECT_URL=https://faucet.sui.io/

# CORS: comma-separated allowed web origins. Unset → permissive (native app
# sends no Origin header). Set this if you add a browser client.
# CORS_ALLOWED_ORIGINS=https://app.example.com

# Payment links: durable store (Postgres). Unset → link endpoints are disabled
# (the rest of the relay still works). On Render this is wired from the managed
# Postgres in render.yaml.
# DATABASE_URL=postgres://user:pass@host:5432/brisk

# Public https origin used to build shareable /p/<code> link URLs. Falls back to
# the request host when unset (fine for local/ngrok).
# PUBLIC_BASE_URL=https://brisk-z5bu.onrender.com

# ──────────────────────────────────────────────────────────────────────────
# Coinbase CDP — fiat onramp/offramp (buy/sell USDC on Sui).
# On Render these are set BY HAND in the dashboard ENV (render.yaml is not wired
# to the live service). Server-side only — the CDP secret never ships in the app.
# ──────────────────────────────────────────────────────────────────────────
# CDP Secret API key (NOT a Client key). From the CDP portal → API Keys.
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
# Hosted widget environment: `sandbox` (default; test card 4242…, no real money)
# or `production`. The CDP token API host is the same in both.
# CDP_ENV=sandbox
# Completion-webhook signing secret (returned when you register the webhook via
# the CDP CLI). Unset → webhook accepts unsigned (dev only); the app polls the
# balance regardless, so onramp UX works without it.
# CDP_WEBHOOK_SECRET=
# Where Coinbase returns the user after a ramp. CDP's domain allowlist only
# accepts https DOMAINS (not custom schemes), so the app return is an https
# bounce (/onramp/return) that 302s to the brisk:// deep link. Both default to
# PUBLIC_BASE_URL when unset. Allowlist the DOMAIN (e.g. brisk-z5bu.onrender.com)
# in the CDP portal → Security Configuration → Add domain.
# COINBASE_ONRAMP_REDIRECT=https://brisk-z5bu.onrender.com/onramp/return
# COINBASE_ONRAMP_WEB_REDIRECT=https://brisk-z5bu.onrender.com/pay/onramp-return
# The deep link the https bounce redirects to (intercepted by expo-web-browser).
# COINBASE_ONRAMP_DEEPLINK=brisk://onramp-return
