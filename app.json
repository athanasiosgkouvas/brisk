{
  "expo": {
    "name": "Brisk",
    "slug": "brisk",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "brisk",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gkouvas.brisk"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "monochromeImage": "./assets/images/icon-monochrome.png",
        "backgroundColor": "#07111A"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.gkouvas.brisk"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#07111A",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain"
        }
      ],
      [
        "react-native-nfc-manager",
        {
          "nfcPermission": "Brisk uses NFC to let you tap and pay merchants.",
          "selectIdentifiers": ["D2760000850101"]
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Brisk uses Face ID to authorize your payments."
        }
      ],
      "./plugins/withBriskHce",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
