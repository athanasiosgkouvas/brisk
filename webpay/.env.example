# Brisk web pay app (Vite). Copy to `.env` for local dev; set the same as build-
# time env in Render for the backend that builds+serves this SPA.

# Backend that mints/resolves links and marks them paid (same origin in prod).
VITE_BACKEND_URL=https://brisk-z5bu.onrender.com

# Enoki PUBLIC api key (zkLogin) — the same public key the app uses.
VITE_ENOKI_API_KEY=

# Google OAuth *Web* client id. MUST list the SPA origin as an authorized JS
# origin and `<origin>/pay/` as an authorized redirect URI. The app's native
# client id will NOT work here.
VITE_GOOGLE_CLIENT_ID=

# Where Google returns the id_token. Defaults to `<current origin>/pay/`.
# VITE_WEB_REDIRECT_URI=https://brisk-z5bu.onrender.com/pay/

# Sui network + optional keyed GraphQL endpoint (blank → public graphql fullnode).
VITE_SUI_NETWORK=testnet
VITE_SUI_RPC_URL=

# Circle USDC coin type (testnet default matches the app).
VITE_USDC_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC

# Coinbase onramp surface (buy USDC on Sui). Feature flag only — backend holds
# all Coinbase config. Set to false to hide the "Add funds" affordance.
# VITE_COINBASE_ENABLED=true
