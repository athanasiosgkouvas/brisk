# ──────────────────────────────────────────────────────────────────────────
# Brisk — frontend (Expo) env. Copy to .env and fill in. EXPO_PUBLIC_* vars
# are inlined into the app bundle (public — never put secrets here).
# ──────────────────────────────────────────────────────────────────────────

# Enoki PUBLIC API key (zkLogin nonce/proof). From the Brisk app in the Enoki portal.
EXPO_PUBLIC_ENOKI_API_KEY=
# Google OAuth 2.0 Web client ID (id_token flow), registered in the Enoki app.
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Web-only OAuth redirect (dev). Native (iOS/Android) uses the brisk://oauth deep link
# via the backend /auth/callback proxy — see EXPO_PUBLIC_BACKEND_URL below.
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:8081

EXPO_PUBLIC_SUI_NETWORK=testnet

# Brisk Move package (testnet) — republished 2026-06-01.
EXPO_PUBLIC_BRISK_PACKAGE_ID=0x2e7adfe10328a4bccf77e1bb6fc1f3b57304c26cfc3dfca61a5664bc23072614
# Shared mock_lender LendingPool<USDC> id + its APY in basis points (1000 = 10%).
EXPO_PUBLIC_BRISK_POOL_ID=0x085c625bf691f70058e2d82e50ed8a803cb7b2d8eb4945f6aef1b623b2f4d553
EXPO_PUBLIC_BRISK_APY_BPS=1000

# Circle testnet USDC — verified, and gasless `send_funds` is enabled for it.
EXPO_PUBLIC_USDC_TYPE=0xa1ec7fc00a6f40db9693ad1415d0c193ad3906494428cf252621037bd7117e29::usdc::USDC
EXPO_PUBLIC_USDC_DECIMALS=6
EXPO_PUBLIC_USDC_SYMBOL=USDC

# Yield-spread revenue (cut of generated yield, not of payments). 1000 = 10%.
EXPO_PUBLIC_YIELD_SPREAD_BPS=1000
# Treasury that receives the yield-spread slice. MUST also be added to the
# Enoki app's allowed-addresses, or sponsored txs paying it get rejected.
EXPO_PUBLIC_BRISK_TREASURY_ADDR=

# For native OAuth (iOS/Android) this MUST be a public backend URL (not
# localhost) — the device browser can't reach localhost. The backend
# /auth/callback proxies Google's redirect to brisk://oauth so expo-web-browser
# can intercept it. Register https://<backend-domain>/auth/callback as an
# Authorized Redirect URI on the Google Web client.
# Live hosted relay (judges can use this as-is); or http://localhost:3001 for local dev.
EXPO_PUBLIC_BACKEND_URL=https://brisk-z5bu.onrender.com
