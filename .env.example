EXPO_PUBLIC_ENOKI_API_KEY=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
# Web OAuth redirect URI (web only). Native uses app callback URI fathom://oauth.
EXPO_PUBLIC_GOOGLE_REDIRECT_URI=http://localhost:8081
EXPO_PUBLIC_SUI_NETWORK=testnet
EXPO_PUBLIC_PREDICT_API_URL=https://predict-server.testnet.mystenlabs.com
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_FIXED_BET_AMOUNT=5
EXPO_PUBLIC_PREDICT_PACKAGE_ID=0xf5ea2b3749c65d6e56507cc35388719aadb28f9cab873696a2f8687f5c785138
EXPO_PUBLIC_PREDICT_OBJECT_ID=0xc8736204d12f0a7277c86388a68bf8a194b0a14c5538ad13f22cbd8e2a38028a
# Fathom's own Move package (move/fathom_router) — router::assert_and_record enforces the Smart Bet DeepBook fill.
EXPO_PUBLIC_FATHOM_ROUTER_PACKAGE_ID=0x92555862cc0dbcedfd6f7ff15bc5ebf42e5bc33e81bf87dac0e611bf45e1c89c
EXPO_PUBLIC_PREDICT_REGISTRY_ID=0x43af14fed5480c20ff77e2263d5f794c35b9fab7e2212903127062f4fe2a6e64
EXPO_PUBLIC_DUSDC_TYPE=0xe95040085976bfd54a1a07225cd46c8a2b4e8e2b6732f140a0fc49850ba73e1a::dusdc::DUSDC
EXPO_PUBLIC_BACKEND_URL=http://localhost:3001

# ──────────────────────────────────────────────────────────────────────────
# DeepBook v3 — Smart Bet hedge leg + standalone swap panel
# ──────────────────────────────────────────────────────────────────────────
# Testnet defaults (verified by scripts/probe-deepbook.ts). To go live on
# mainnet, swap these for the values exported by `@mysten/deepbook-v3`'s
# `mainnetPackageIds` / `mainnetPools` / `mainnetCoins` — the SUI/USDC pool
# is the natural mainnet counterpart to the testnet SUI/DBUSDC pool.
EXPO_PUBLIC_DEEPBOOK_PACKAGE_ID=0x22be4cade64bf2d02412c7e8d0e8beea2f78828b948118d46735315409371a3c
EXPO_PUBLIC_DEEPBOOK_SUI_QUOTE_POOL=0x1c19362ca52b8ffd7a33cee805a67d40f31e6ba303753fd3a4cfdfacea7163a5
EXPO_PUBLIC_DEEPBOOK_QUOTE_TYPE=0xf7152c05930480cd740d7311b5b8b45c6f488e3a53a11c3f74a6fac36a52e0d7::DBUSDC::DBUSDC
EXPO_PUBLIC_DEEPBOOK_QUOTE_SYMBOL=DBUSDC
EXPO_PUBLIC_DEEPBOOK_QUOTE_DECIMALS=6
EXPO_PUBLIC_DEEPBOOK_DEEP_TYPE=0x36dbef866a1d62bf7328989a10fb2f07d769f4ee587c0de4a0a256e57e0a58a8::deep::DEEP

# ──────────────────────────────────────────────────────────────────────────
# Fathom revenue — claim take-rate (skim inside the redeem PTB)
# ──────────────────────────────────────────────────────────────────────────
# Treasury address MUST also be added to the Enoki app's allowed-addresses
# in the Enoki dashboard, otherwise sponsored claims will be rejected with
# "Address … is not allow-listed for receiving transfers". Set fee to 0 to
# disable the skim entirely (no PTB-level change required).
EXPO_PUBLIC_FATHOM_CLAIM_FEE_BPS=0
EXPO_PUBLIC_FATHOM_TREASURY_ADDR=

# For native OAuth (Android/iOS), this must be the deployed public backend URL (not localhost),
# since the device browser cannot reach localhost. The backend /auth/callback endpoint
# proxies Google's redirect to the fathom:// deep link so expo-web-browser can intercept it.
# Register https://<your-backend-domain>/auth/callback in Google Cloud Console as an
# Authorized Redirect URI on your web client ID.
